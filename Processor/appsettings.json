{
  "Kafka": {
    "Brokers": ["localhost:9092"],
    "ConsumerGroupId": "message-processor-group",
    "InputTopic": "input-topic",
    "OutputTopic": "output-topic",
    "WorkersCount": 10,
    "BufferSize": 100
  },
  "Benchmark": {
    "WorkMicros": 0
  },
  "OpenTelemetry": {
    "OtlpEndpoint": "http://localhost:8200",
    "ServiceName": "kafkaflow-processor",
    "ServiceVersion": "1.0.0",
    "Environment": "development",
    "Site": "local"
  },
  "Metrics": {
    "Port": 8080
  },
  "Redis": {
    "ConnectionString": "localhost:6379"
  },
  "DataTypeSettings": {
    "HashKey": "datatype:settings",
    "RefreshSeconds": 15,
    "HeaderName": "data-type-id"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.Hosting.Lifetime": "Information"
    }
  }
}
