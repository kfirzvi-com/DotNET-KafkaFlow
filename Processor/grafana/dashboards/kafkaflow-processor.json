{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "title": "KafkaFlow Processor",
  "tags": ["kafkaflow", "otel"],
  "time": { "from": "now-15m", "to": "now" },
  "refresh": "5s",
  "templating": { "list": [] },
  "panels": [
    {
      "type": "stat",
      "title": "Processed (total)",
      "gridPos": { "h": 4, "w": 5, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "unit": "short" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "sum(messages_processed_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "stat",
      "title": "Filtered (total)",
      "gridPos": { "h": 4, "w": 5, "x": 5, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "purple" }, "unit": "short" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "sum(messages_filtered_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "stat",
      "title": "Dead-lettered (total)",
      "gridPos": { "h": 4, "w": 5, "x": 10, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "red" }, "unit": "short" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "sum(messages_dead_lettered_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "stat",
      "title": "Dropped (total)",
      "gridPos": { "h": 4, "w": 5, "x": 15, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "orange" }, "unit": "short" }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "sum(messages_dropped_total)", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "stat",
      "title": "Throughput (msg/s)",
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "blue" }, "unit": "ops", "decimals": 2 }, "overrides": [] },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "sum(rate(messages_processing_duration_milliseconds_count[1m]))", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Message outcomes (rate/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15, "stacking": { "mode": "normal" } }, "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "lastNotNull"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "legendFormat": "processed", "expr": "sum(rate(messages_processed_total[1m]))", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "legendFormat": "filtered", "expr": "sum(rate(messages_filtered_total[1m]))", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "C", "legendFormat": "dead-lettered", "expr": "sum(rate(messages_dead_lettered_total[1m]))", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "D", "legendFormat": "dropped", "expr": "sum(rate(messages_dropped_total[1m]))", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Filtered by reason (rate/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 20, "stacking": { "mode": "normal" } }, "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "lastNotNull"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "legendFormat": "{{reason}}", "expr": "sum by (reason) (rate(messages_filtered_total[1m]))", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Processing duration (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "legendFormat": "p50", "expr": "histogram_quantile(0.50, sum(rate(messages_processing_duration_milliseconds_bucket[5m])) by (le))", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "legendFormat": "p95", "expr": "histogram_quantile(0.95, sum(rate(messages_processing_duration_milliseconds_bucket[5m])) by (le))", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "C", "legendFormat": "p99", "expr": "histogram_quantile(0.99, sum(rate(messages_processing_duration_milliseconds_bucket[5m])) by (le))", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Process memory (working set)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "bytes" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "legendFormat": "working set", "expr": "dotnet_process_memory_working_set_bytes", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis operations (ops/s) by op & status",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15 }, "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "lastNotNull"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "legendFormat": "{{operation}} ({{status}})", "expr": "sum by (operation, status) (rate(redis_operations_total[1m]))", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Redis latency (ms)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "legendFormat": "p50", "expr": "histogram_quantile(0.50, sum(rate(redis_operation_duration_milliseconds_bucket[5m])) by (le))", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "legendFormat": "p95", "expr": "histogram_quantile(0.95, sum(rate(redis_operation_duration_milliseconds_bucket[5m])) by (le))", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "C", "legendFormat": "p99", "expr": "histogram_quantile(0.99, sum(rate(redis_operation_duration_milliseconds_bucket[5m])) by (le))", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "GC collections & CPU (rate/s)",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 28 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "lastNotNull"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "legendFormat": "gc {{gc_heap_generation}}", "expr": "sum by (gc_heap_generation) (rate(dotnet_gc_collections_total[1m]))", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "legendFormat": "cpu seconds/s", "expr": "rate(dotnet_process_cpu_time_seconds_total[1m])", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "row", "title": "Kafka consumer (librdkafka statistics)", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 36 }
    },
    {
      "type": "timeseries",
      "title": "Consumer lag (messages)",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15 }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "legendFormat": "lag", "expr": "kafka_consumer_lag", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Assignment & rebalances",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "legendFormat": "assigned partitions", "expr": "kafka_consumer_assignment_partitions", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "legendFormat": "rebalances (total)", "expr": "kafka_consumer_rebalances_total", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Broker RTT (ms)",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 37 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "ms" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "max"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "legendFormat": "avg", "expr": "kafka_broker_rtt_avg_milliseconds", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "legendFormat": "max", "expr": "kafka_broker_rtt_max_milliseconds", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Consumer rx rate (msg/s) & fetch queue",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 45 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "short" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "calcs": ["mean", "lastNotNull"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "legendFormat": "rx msg/s", "expr": "rate(kafka_consumer_rx_messages_total[1m])", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "legendFormat": "fetch queue depth", "expr": "kafka_consumer_fetchq_messages", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "row", "title": "Settings & Redis health", "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 53 }
    },
    {
      "type": "stat",
      "title": "Settings snapshot size",
      "gridPos": { "h": 6, "w": 6, "x": 0, "y": 54 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "color": { "mode": "fixed", "fixedColor": "green" }, "unit": "short" }, "overrides": [] },
      "options": { "colorMode": "value", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        { "refId": "A", "expr": "datatype_settings_snapshot_size", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Seconds since last successful load",
      "gridPos": { "h": 6, "w": 9, "x": 6, "y": 54 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 10 }, "unit": "s" }, "overrides": [] },
      "options": { "legend": { "displayMode": "list", "placement": "bottom" }, "tooltip": { "mode": "single" } },
      "targets": [
        { "refId": "A", "legendFormat": "since load", "expr": "datatype_settings_since_load_seconds", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    },
    {
      "type": "timeseries",
      "title": "Settings reloads vs load failures (rate/s)",
      "gridPos": { "h": 6, "w": 9, "x": 15, "y": 54 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "fillOpacity": 15 }, "unit": "ops" }, "overrides": [] },
      "options": { "legend": { "displayMode": "table", "calcs": ["lastNotNull"], "placement": "bottom" }, "tooltip": { "mode": "multi" } },
      "targets": [
        { "refId": "A", "legendFormat": "reloads", "expr": "rate(datatype_settings_reloads_total[5m])", "datasource": { "type": "prometheus", "uid": "prometheus" } },
        { "refId": "B", "legendFormat": "load failures", "expr": "rate(datatype_settings_load_failures_total[5m])", "datasource": { "type": "prometheus", "uid": "prometheus" } }
      ]
    }
  ]
}
